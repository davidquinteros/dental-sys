# Config para `docker compose up` en LOCAL (docker-compose.yml la lee sola).
# Copiá este archivo a `.env` en la raíz del repo y completá con los valores
# reales del proyecto Supabase "dental-sys-testing" (Settings > Database >
# Connection string, modo "Session pooler", puerto 5432 — NO el transaction
# pooler puerto 6543). `.env` está gitignored: se completa UNA sola vez acá
# en tu máquina y nunca más se toca ni se commitea.
#
# El backend (ver backend/entrypoint.sh) corre `flask db upgrade` automático
# contra MIGRATIONS_DATABASE_URL cada vez que el contenedor arranca, así que
# con esto seteado una vez, "docker compose up" siempre deja la base de
# testing al día — no hace falta migrar a mano.

# Rol dental_app (restringido, usado en runtime — ver create_app_role.sql)
DATABASE_URL=postgresql://dental_app:LA_PASSWORD_QUE_PUSISTE@HOST_DEL_POOLER:5432/postgres

# Rol postgres (dueño del schema, solo para migraciones)
MIGRATIONS_DATABASE_URL=postgresql://postgres:LA_PASSWORD_DEL_PROYECTO@HOST_DEL_POOLER:5432/postgres

# Mismo host/puerto/usuario que MIGRATIONS_DATABASE_URL — solo se usan para
# el wait-loop (pg_isready) de entrypoint.sh antes de migrar.
POSTGRES_HOST=HOST_DEL_POOLER
POSTGRES_PORT=5432
POSTGRES_USER=postgres

# Supabase Storage — fotos clínicas (FCLI-10), mismo proyecto de testing.
SUPABASE_URL=https://tu-proyecto-testing-ref.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key-de-testing
SUPABASE_STORAGE_BUCKET=treatment-images
