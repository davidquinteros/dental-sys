# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-super-secret-key-change-in-production

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/dental_clinic_db

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# CORS
CORS_ORIGINS=http://localhost:4200

# Gunicorn (see entrypoint.sh) — tune to the deployment's actual CPU/RAM.
# Total Postgres connections used is roughly WEB_CONCURRENCY * (DB_POOL_SIZE + DB_MAX_OVERFLOW);
# keep that under the database's max_connections (or its pooler's limit).
#
# Values below = current tier (Render free / Supabase free). Set these
# explicitly in Render's dashboard (Environment tab) when upgrading plans —
# no code change needed. Suggested values for a Render Standard (1+ CPU,
# 2GB+ RAM) + Supabase Pro pairing, as a starting point to load-test from:
#   WEB_CONCURRENCY=4   WEB_THREADS=4
#   DB_POOL_SIZE=8      DB_MAX_OVERFLOW=8   (max 4*(8+8)=64 connections — check
#                                            against the Supabase plan's actual
#                                            pooler/connection limit before going live)
# Always re-run the concurrency load test against the upgraded environment
# itself before relying on these — don't assume local results carry over.
WEB_CONCURRENCY=2
WEB_THREADS=2
WEB_TIMEOUT=60

# SQLAlchemy connection pool (per gunicorn worker)
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=280